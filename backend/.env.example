PORT=4000
CORS_ORIGIN=*

# Keep this true until real Aryeo credentials and endpoint paths are confirmed.
USE_MOCK_ARYEO=true
ARYEO_API_BASE_URL=https://api.aryeo.com/v1

# Add the real token only on the backend. Never expose it in the iPhone app.
ARYEO_API_TOKEN=

# Set AI_PROVIDER=openai and add OPENAI_API_KEY when you are ready for live AI.
AI_PROVIDER=mock
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
